<?xml version="1.0" encoding="utf-8"?>
<!--
    res/layout/exo_player_controller.xml
    Styled to match ott_player_ui_mockup.html
    + A/V Sync button added between btn_aspect_ratio and btn_fullscreen
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/player_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#00000000"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- TOP SCRIM: 28% height, strong black→transparent -->
    <View
        android:id="@+id/scrim_top"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:layout_gravity="top"
        android:background="@drawable/gradient_top_scrim" />

    <!-- BOTTOM SCRIM: 35% height, stronger fade -->
    <View
        android:id="@+id/scrim_bottom"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_gravity="bottom"
        android:background="@drawable/gradient_bottom_scrim" />

    <!-- GESTURE ZONES -->
    <View
        android:id="@+id/zone_brightness"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#00000000"
        android:contentDescription="Brightness gesture area" />

    <View
        android:id="@+id/zone_volume"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="#00000000"
        android:contentDescription="Volume gesture area" />

    <!-- ═══════════════════════════════════════
         TOP BAR
         gap: 8dp between items, 14dp top pad
    ═══════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="10dp">

        <!-- Back — 36×36 circle -->
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_icon_btn"
            android:src="@drawable/ic_chevron_left"
            android:tint="#FFFFFFFF"
            android:contentDescription="Back"
            android:padding="9dp"
            android:focusable="true"
            android:nextFocusRight="@id/btn_mute"
            android:nextFocusDown="@id/exo_rew" />

        <!-- Title -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Now Playing"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp"
            android:textStyle="normal"
            android:letterSpacing="0.01"
            android:shadowColor="#CC000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="6"
            android:focusable="false" />

        <!-- Episode Badge -->
        <TextView
            android:id="@+id/mp_ep_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_seek_pill"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:text="S1 • E1"
            android:textColor="#FFFFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- Mute -->
        <ImageButton
            android:id="@+id/btn_mute"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_icon_btn"
            android:src="@drawable/ic_volume_up"
            android:tint="#FFFFFFFF"
            android:contentDescription="Mute"
            android:padding="9dp"
            android:focusable="true"
            android:nextFocusLeft="@id/btn_back"
            android:nextFocusRight="@id/btn_aspect_ratio"
            android:nextFocusDown="@id/exo_play_pause" />

        <!-- Aspect Ratio -->
        <ImageButton
            android:id="@+id/btn_aspect_ratio"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_icon_btn"
            android:src="@drawable/ic_aspect_ratio"
            android:tint="#FFFFFFFF"
            android:contentDescription="Aspect ratio"
            android:padding="9dp"
            android:focusable="true"
            android:nextFocusLeft="@id/btn_mute"
            android:nextFocusRight="@id/btn_sync"
            android:nextFocusDown="@id/exo_play_pause" />

        <!-- ═══════════════════════════════════════
             A/V SYNC — NEW BUTTON
             Tap to open the sync adjustment dialog.
             Use ic_sync vector drawable (see below).
        ═══════════════════════════════════════ -->
        <ImageButton
            android:id="@+id/btn_sync"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_icon_btn"
            android:src="@drawable/ic_sync"
            android:tint="#FFFFFFFF"
            android:contentDescription="A/V Sync"
            android:padding="9dp"
            android:focusable="true"
            android:nextFocusLeft="@id/btn_aspect_ratio"
            android:nextFocusRight="@id/btn_fullscreen"
            android:nextFocusDown="@id/exo_play_pause" />

        <!-- Fullscreen -->
        <ImageButton
            android:id="@+id/btn_fullscreen"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_icon_btn"
            android:src="@drawable/ic_fullscreen"
            android:tint="#FFFFFFFF"
            android:contentDescription="Fullscreen"
            android:padding="9dp"
            android:focusable="true"
            android:nextFocusLeft="@id/btn_sync"
            android:nextFocusDown="@id/exo_ffwd" />

    </LinearLayout>

    <!-- ═══════════════════════════════════════
         CENTER CONTROLS
         rew 52dp | play 60dp | ffwd 52dp
    ═══════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/center_controls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Previous Episode -->
        <ImageButton
            android:id="@+id/btn_prev_ep"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_ctrl_side"
            android:src="@drawable/ic_step_backward"
            android:tint="#FFFFFFFF"
            android:contentDescription="Previous Episode"
            android:padding="12dp"
            android:visibility="gone"
            android:focusable="true" />

        <!-- Rewind 10s -->
        <ImageButton
            android:id="@+id/exo_rew"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_ctrl_side"
            android:src="@drawable/ic_replay_10"
            android:tint="#FFFFFFFF"
            android:contentDescription="Rewind 10 seconds"
            android:padding="12dp"
            android:focusable="true"
            android:elevation="0dp"
            android:outlineProvider="none"
            android:nextFocusRight="@id/exo_play_pause"
            android:nextFocusUp="@id/btn_back"
            android:nextFocusDown="@id/exo_progress" />

        <!-- Play/Pause -->
        <ImageButton
            android:id="@+id/exo_play_pause"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/bg_ctrl_play"
            android:src="@drawable/ic_play"
            android:tint="#FFFFFFFF"
            android:contentDescription="Play/Pause"
            android:padding="15dp"
            android:focusable="true"
            android:elevation="0dp"
            android:outlineProvider="none"
            android:nextFocusLeft="@id/exo_rew"
            android:nextFocusRight="@id/exo_ffwd"
            android:nextFocusUp="@id/btn_mute"
            android:nextFocusDown="@id/exo_progress" />

        <!-- Forward 10s -->
        <ImageButton
            android:id="@+id/exo_ffwd"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_ctrl_side"
            android:src="@drawable/ic_forward_30"
            android:tint="#FFFFFFFF"
            android:contentDescription="Forward 10 seconds"
            android:padding="12dp"
            android:focusable="true"
            android:elevation="0dp"
            android:outlineProvider="none"
            android:nextFocusLeft="@id/exo_play_pause"
            android:nextFocusUp="@id/btn_fullscreen"
            android:nextFocusDown="@id/exo_progress" />

        <!-- Next Episode -->
        <ImageButton
            android:id="@+id/btn_next_ep"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_ctrl_side"
            android:src="@drawable/ic_step_forward"
            android:tint="#FFFFFFFF"
            android:contentDescription="Next Episode"
            android:padding="12dp"
            android:visibility="gone"
            android:focusable="true" />

    </LinearLayout>

    <!-- ═══════════════════════════════════════
         BRIGHTNESS PILL (left)
    ═══════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/gesture_brightness_indicator"
        android:layout_width="52dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|start"
        android:layout_marginStart="18dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_gesture_pill"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:visibility="gone"
        android:elevation="8dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_brightness"
            android:tint="#FFFFFFFF"
            android:layout_marginBottom="8dp" />

        <FrameLayout
            android:layout_width="6dp"
            android:layout_height="80dp">

            <View
                android:layout_width="6dp"
                android:layout_height="80dp"
                android:background="@drawable/bg_pill_track" />

            <View
                android:id="@+id/view_brightness_fill"
                android:layout_width="6dp"
                android:layout_height="80dp"
                android:layout_gravity="bottom"
                android:background="@drawable/bg_pill_fill"
                android:scaleY="0.55"
                android:transformPivotY="80dp" />

        </FrameLayout>

        <TextView
            android:id="@+id/tv_brightness_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="55%"
            android:textColor="#FFFFFFFF"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:textStyle="normal" />

    </LinearLayout>

    <!-- ═══════════════════════════════════════
         VOLUME PILL (right)
    ═══════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/gesture_volume_indicator"
        android:layout_width="52dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|end"
        android:layout_marginEnd="18dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_gesture_pill"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:visibility="gone"
        android:elevation="8dp">

        <ImageView
            android:id="@+id/ic_volume_gesture"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_volume_up"
            android:tint="#FFFFFFFF"
            android:layout_marginBottom="8dp" />

        <FrameLayout
            android:layout_width="6dp"
            android:layout_height="80dp">

            <View
                android:layout_width="6dp"
                android:layout_height="80dp"
                android:background="@drawable/bg_pill_track" />

            <View
                android:id="@+id/view_volume_fill"
                android:layout_width="6dp"
                android:layout_height="80dp"
                android:layout_gravity="bottom"
                android:background="@drawable/bg_pill_fill"
                android:scaleY="0.7"
                android:transformPivotY="80dp" />

        </FrameLayout>

        <TextView
            android:id="@+id/tv_volume_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="70%"
            android:textColor="#FFFFFFFF"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:textStyle="normal" />

    </LinearLayout>

    <!-- ═══════════════════════════════════════
         SEEK INDICATOR PILL (center)
    ═══════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/seek_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_seek_pill"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:visibility="gone"
        android:elevation="8dp">

        <ImageView
            android:id="@+id/seek_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_forward_30"
            android:tint="#FFFFFFFF" />

        <TextView
            android:id="@+id/tv_seek_delta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="+10s"
            android:textColor="#FFFFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.02" />

    </LinearLayout>

    <!-- ═══════════════════════════════════════
         EPISODE LIST (OTT STYLE)
    ═══════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/episode_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="110dp"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EPISODES"
            android:textColor="#80FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/episode_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical" />
        </HorizontalScrollView>
    </LinearLayout>

    <!-- ═══════════════════════════════════════
         BOTTOM BAR
    ═══════════════════════════════════════ -->
    <!-- PREVIEW THUMBNAIL CONTAINER -->
    <LinearLayout
        android:id="@+id/preview_container"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginBottom="85dp">

        <FrameLayout
            android:layout_width="120dp"
            android:layout_height="68dp"
            android:background="@drawable/bg_preview_frame">

            <ImageView
                android:id="@+id/preview_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:layout_margin="1.5dp" />
        </FrameLayout>

        <TextView
            android:id="@+id/preview_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_seek_pill"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:text="00:00"
            android:textColor="#FFFFFF"
            android:textSize="10sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp">

        <!-- Time row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="6dp">

            <TextView
                android:id="@+id/exo_position"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFFFF"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:textStyle="normal"
                android:letterSpacing="0.03"
                android:text="0:00:00"
                android:minWidth="48dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" /"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/exo_duration"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:text="0:00:00" />

        </LinearLayout>

        <!-- Progress bar -->
        <androidx.media3.ui.DefaultTimeBar
            android:id="@+id/exo_progress"
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:focusable="true"
            android:nextFocusUp="@id/exo_play_pause"
            app:played_color="#FFFFFFFF"
            app:buffered_color="#59FFFFFF"
            app:unplayed_color="#33FFFFFF"
            app:scrubber_color="#FFFFFFFF"
            app:scrubber_dragged_size="14dp"
            app:scrubber_enabled_size="12dp"
            app:scrubber_disabled_size="0dp"
            app:bar_height="3dp"
            app:touch_target_height="24dp" />

    </LinearLayout>

    <!-- BUFFERING SPINNER -->
    <ProgressBar
        android:id="@+id/exo_buffering"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="center"
        android:indeterminateTint="#FFFFFFFF"
        android:visibility="gone" />

    <!-- DOUBLE-TAP RIPPLES -->
    <View
        android:id="@+id/ripple_left"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:layout_gravity="start|center_vertical"
        android:background="@drawable/bg_tap_ripple"
        android:visibility="gone" />

    <View
        android:id="@+id/ripple_right"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:layout_gravity="end|center_vertical"
        android:background="@drawable/bg_tap_ripple"
        android:visibility="gone" />

</FrameLayout>