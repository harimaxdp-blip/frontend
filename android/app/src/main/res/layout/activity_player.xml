<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        app:resize_mode="fill"
        app:use_controller="true"
        app:controller_layout_id="@layout/exo_player_control_view"
        app:show_buffering="when_playing"
        app:surface_type="texture_view" />

    <com.pierfrancescosoffritti.androidyoutubeplayer.core.player.views.YouTubePlayerView
        android:id="@+id/youtube_player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:enableAutomaticInitialization="false" />

    <!-- LOCK BUTTON — outside PlayerView so touch always reaches it -->
    <ImageButton
        android:id="@+id/btn_lock"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="center_vertical|end"
        android:layout_marginEnd="24dp"
        android:background="@drawable/bg_lock_btn"
        android:contentDescription="Lock controls"
        android:src="@drawable/ic_lock_open"
        app:tint="#FFFFFFFF"
        android:padding="8dp"
        android:focusable="false"
        android:visibility="gone" />

    <!-- LOCK HINT — outside PlayerView -->
    <TextView
        android:id="@+id/tv_lock_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|end"
        android:layout_marginEnd="80dp"
        android:background="@drawable/bg_seek_pill"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:text="Tap 🔒 to unlock"
        android:textColor="#FFFFFFFF"
        android:textSize="12sp"
        android:visibility="gone" />

</FrameLayout>