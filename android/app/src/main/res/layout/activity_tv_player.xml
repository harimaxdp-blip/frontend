<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/player_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:keepScreenOn="true">

    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="false"
        android:focusableInTouchMode="false" />

    <View
        android:id="@+id/scrim_top"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:layout_gravity="top"
        android:background="@drawable/gradient_top_scrim"
        android:alpha="0"
        android:focusable="false" />

    <View
        android:id="@+id/scrim_bottom"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_gravity="bottom"
        android:background="@drawable/gradient_bottom_scrim"
        android:alpha="0"
        android:focusable="false" />

    <FrameLayout
        android:id="@+id/controls_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0"
        android:visibility="invisible"
        android:focusable="false">

        <LinearLayout
            android:id="@+id/top_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="48dp"
            android:paddingEnd="48dp"
            android:paddingTop="20dp"
            android:paddingBottom="16dp">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_chevron_left"
                android:background="@drawable/bg_icon_btn"
                android:padding="10dp"
                android:contentDescription="Back"
                android:focusable="true"
                android:clickable="true"
                android:nextFocusRight="@+id/top_bar_spacer" />

            <Space
                android:id="@+id/top_bar_spacer"
                android:layout_width="16dp"
                android:layout_height="1dp"
                android:focusable="false" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_video_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loading..."
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tv_episode_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#99FFFFFF"
                    android:textSize="13sp"
                    android:layout_marginTop="2dp"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_quality_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1080p"
                android:textColor="#5C8AF5"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_ep_chip"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:layout_marginEnd="16dp"
                android:focusable="false" />

            <TextClock
                android:id="@+id/tv_clock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:format12Hour="h:mm a"
                android:format24Hour="HH:mm"
                android:textColor="#66FFFFFF"
                android:textSize="13sp"
                android:focusable="false" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/center_controls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btn_prev_episode"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_step_backward"
                android:background="@drawable/bg_icon_btn"
                android:padding="12dp"
                android:contentDescription="Previous episode"
                android:focusable="true"
                android:clickable="true"
                android:layout_marginEnd="20dp" />

            <ImageView
                android:id="@+id/btn_rewind"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_replay_10"
                android:background="@drawable/bg_icon_btn"
                android:padding="14dp"
                android:contentDescription="Rewind 10 seconds"
                android:focusable="true"
                android:clickable="true"
                android:layout_marginEnd="24dp" />

            <ImageView
                android:id="@+id/btn_play_pause"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_play"
                android:background="@drawable/bg_ctrl_play"
                android:padding="18dp"
                android:contentDescription="Play"
                android:focusable="true"
                android:clickable="true"
                android:layout_marginEnd="24dp"
                android:nextFocusUp="@+id/btn_back"
                android:nextFocusDown="@+id/seek_bar"
                android:nextFocusLeft="@+id/btn_rewind"
                android:nextFocusRight="@+id/btn_forward" />

            <ImageView
                android:id="@+id/btn_forward"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_forward_30"
                android:background="@drawable/bg_icon_btn"
                android:padding="14dp"
                android:contentDescription="Forward 30 seconds"
                android:focusable="true"
                android:clickable="true"
                android:layout_marginEnd="20dp" />

            <ImageView
                android:id="@+id/btn_next_episode"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_step_forward"
                android:background="@drawable/bg_icon_btn"
                android:padding="12dp"
                android:contentDescription="Next episode"
                android:focusable="true"
                android:clickable="true" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/bottom_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:paddingStart="48dp"
            android:paddingEnd="48dp"
            android:paddingBottom="24dp">

            <FrameLayout
                android:id="@+id/seek_preview_container"
                android:layout_width="160dp"
                android:layout_height="90dp"
                android:layout_marginBottom="8dp"
                android:layout_gravity="start"
                android:visibility="gone"
                android:elevation="8dp">

                <ImageView
                    android:id="@+id/seek_preview_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_preview_frame"
                    android:scaleType="centerCrop" />

                <TextView
                    android:id="@+id/seek_preview_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="4dp"
                    android:text="00:00"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="#80000000"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <TextView
                    android:id="@+id/tv_current_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:focusable="false" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tv_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="45:00"
                    android:textColor="#66FFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:focusable="false" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/seek_bar"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:max="1000"
                android:progressTint="#E50914"
                android:secondaryProgressTint="#44FFFFFF"
                android:thumbTint="#E50914"
                android:background="@null"
                android:focusable="true"
                android:nextFocusUp="@+id/btn_play_pause"
                android:nextFocusRight="@+id/btn_settings" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:layout_marginTop="4dp">

                <ImageView
                    android:id="@+id/btn_subtitles"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_subtitles"
                    android:background="@drawable/bg_icon_btn"
                    android:padding="10dp"
                    android:contentDescription="Subtitles"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_marginStart="8dp" />

                <ImageView
                    android:id="@+id/btn_audio"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_tracks"
                    android:background="@drawable/bg_icon_btn"
                    android:padding="10dp"
                    android:contentDescription="Audio"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_marginStart="8dp" />

                <ImageView
                    android:id="@+id/btn_speed"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_equalizer"
                    android:background="@drawable/bg_icon_btn"
                    android:padding="10dp"
                    android:contentDescription="Playback speed"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_marginStart="8dp" />

                <ImageView
                    android:id="@+id/btn_settings"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_settings"
                    android:background="@drawable/bg_icon_btn"
                    android:padding="10dp"
                    android:contentDescription="Settings"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_marginStart="8dp" />

                <ImageView
                    android:id="@+id/btn_episodes"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_episodes"
                    android:background="@drawable/bg_icon_btn"
                    android:padding="10dp"
                    android:contentDescription="Episodes"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_marginStart="8dp" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

</FrameLayout>