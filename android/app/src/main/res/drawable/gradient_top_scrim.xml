<?xml version="1.0" encoding="utf-8"?>
<!--
    gradient_top_scrim.xml
    Black-to-transparent gradient for the top scrim overlay.
    Fades from solid black at the top to fully transparent at the bottom.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <gradient
        android:type="linear"
        android:angle="270"
        android:startColor="#D1000000"
        android:endColor="#00000000" />
</shape>
