<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_preview_frame.xml
    Background frame for the thumbnail preview shown during seekbar scrubbing.
    Dark rounded rectangle with a thin border to separate it from the video.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <solid android:color="#F0000000" />
            <stroke
                android:width="1dp"
                android:color="#33FFFFFF" />
            <corners android:radius="6dp" />
        </shape>
    </item>

</layer-list>
