<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_ctrl_play.xml
    Background for the 72dp play/pause center button.
    Solid white circle. Icon tinted black on top for premium OTT look.
    Ripple gives touch feedback without altering the white surface.
-->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#33000000">

    <item android:id="@android:id/mask">
        <shape android:shape="oval">
            <solid android:color="#FFFFFFFF" />
        </shape>
    </item>

    <item>
        <shape android:shape="oval">
            <solid android:color="#FFFFFFFF" />
        </shape>
    </item>

</ripple>
