<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_gesture_pill.xml
    Background for the brightness and volume gesture indicator pills
    shown on left/right edges during swipe gestures.
    Dark translucent rounded rectangle with a subtle border.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <solid android:color="#CC0A0A14" />
            <stroke
                android:width="0.5dp"
                android:color="#1FFFFFFF" />
            <corners android:radius="28dp" />
        </shape>
    </item>

</layer-list>
